// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects     Project[]
}

model Project {
  id          String         @id @default(uuid())
  name        String
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  keywords    Keyword[]
  concepts    Concept[]
}

model Keyword {
  id         String   @id @default(uuid())
  sourceTerm String
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  concepts   Concept[] @relation("KeywordConcepts")
}

model Concept {
  id                   String    @id @default(uuid())
  definitionHash       String    @unique // To ensure uniqueness based on candidateConceptName + definitionText
  candidateConceptName String    // e.g., "Mounting bracket"
  definitionText       String    // e.g., "Rigid structural component..."
  vectorEmbedding      String?   // JSON serialized Float[]
  
  projectId            String
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  keywords             Keyword[] @relation("KeywordConcepts")
}

// Keeping these around for the actual PDF/Illustration parsing phase
model Illustration {
  id        String   @id @default(uuid())
  title     String?
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  callouts  Callout[]
}

model Callout {
  id             String       @id @default(uuid())
  illustrationId String
  illustration   Illustration @relation(fields: [illustrationId], references: [id], onDelete: Cascade)
  
  identifier     String       // e.g., "7", "A", "arrow-1"
  sourceTerm     String       // e.g., "bracket", "cover"
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
